{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "scripts/**/*.js",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "runtime",
    "src/mcp"
  ]
}
