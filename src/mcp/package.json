{
  "name": "easydb-mcp",
  "version": "1.0.8",
  "description": "MCP server for EasyDB — lets AI tools manage business APIs via natural language",
  "keywords": [
    "mcp",
    "easydb",
    "sql",
    "api-gateway"
  ],
  "license": "MIT",
  "type": "commonjs",
  "main": "src/server.ts",
  "bin": {
    "easydb-mcp": "bin/easydb-mcp"
  },
  "scripts": {
    "start": "node --import tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json",
    "adduser": "npm adduser --registry=https://registry.npmjs.org",
    "publish": "npm publish"
  },
  "files": [
    "src",
    "bin"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "adm-zip": "^0.5.16",
    "form-data": "^4.0.1",
    "tsx": "^4.20.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  }
}
